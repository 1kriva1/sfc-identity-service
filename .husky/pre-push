#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo 'Ready to push changes!'

echo 'Running unit tests...'
dotnet husky run --name dotnet-test

echo 'Generate unit tests report...'
dotnet husky run --name dotnet-reportgenerator-create

echo 'Running npm unit tests & code coverage...'
dotnet husky run --name npm-test

echo 'Completed pre-push changes'